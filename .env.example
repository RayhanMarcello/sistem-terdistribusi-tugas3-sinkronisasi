# =============================================================
# Distributed Sync System - Environment Configuration Example
# =============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================

# -----------------------------------------------
# Node Configuration
# -----------------------------------------------
# Unique identifier for this node (e.g., node1, node2, node3)
NODE_ID=node1

# Host/IP this node listens on (0.0.0.0 = all interfaces)
NODE_HOST=0.0.0.0

# gRPC server port for inter-node communication
GRPC_PORT=50051

# REST API port (FastAPI)
REST_PORT=8000

# Comma-separated list of ALL nodes in cluster format: <node_id>:<grpc_host>:<grpc_port>
CLUSTER_NODES=node1:node1:50051,node2:node2:50051,node3:node3:50051

# Geographic region for this node (us | eu | asia)
GEO_REGION=us

# -----------------------------------------------
# Redis (Distributed State)
# -----------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# Leave empty if no password
REDIS_PASSWORD=rayhan222
REDIS_DB=0

# -----------------------------------------------
# MySQL Database
# -----------------------------------------------
# MySQL is accessible from OUTSIDE the container at localhost:3306
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=distributed_sync
MYSQL_USER=rayhan
MYSQL_PASSWORD=rayhan222
MYSQL_ROOT_PASSWORD=rayhan222

# -----------------------------------------------
# Apache Kafka
# -----------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=dist-sync-group
# Number of partitions for main queue topic
KAFKA_PARTITIONS=6
KAFKA_REPLICATION_FACTOR=1

# -----------------------------------------------
# Security (Bonus D)
# -----------------------------------------------
# Enable mTLS for gRPC communication (true | false)
TLS_ENABLED=true

# Directory where certificates are stored (auto-generated at startup)
CERT_DIR=/app/certs

# JWT secret key for REST API authentication (change this!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# JWT token expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY=3600

# -----------------------------------------------
# Grafana Monitoring
# -----------------------------------------------
# Anonymous access enabled (true = no login required for demo)
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SECURITY_ADMIN_USER=admin
# Grafana port (exposed at localhost:3000)
GRAFANA_PORT=3000

# -----------------------------------------------
# Prometheus
# -----------------------------------------------
PROMETHEUS_PORT=9090
# Metrics endpoint path
METRICS_PORT=9091

# -----------------------------------------------
# ML Load Balancer (Bonus C)
# -----------------------------------------------
# Path to save/load trained model
ML_MODEL_PATH=/app/models/load_balancer.pkl
# Retrain model every N requests
ML_RETRAIN_INTERVAL=100
# Training data size (synthetic)
ML_TRAINING_SAMPLES=1000

# -----------------------------------------------
# Geo-Distributed Simulation (Bonus B)
# -----------------------------------------------
# Simulated latency between regions in milliseconds
GEO_LATENCY_US_EU=100
GEO_LATENCY_US_ASIA=150
GEO_LATENCY_EU_ASIA=120

# -----------------------------------------------
# Lock Manager
# -----------------------------------------------
# Default lock timeout in seconds
LOCK_TIMEOUT=30
# Deadlock detection interval in seconds
DEADLOCK_DETECTION_INTERVAL=5

# -----------------------------------------------
# Cache (MOESI)
# -----------------------------------------------
# Maximum cache entries per node
CACHE_MAX_SIZE=1000
# Cache replacement policy (lru | lfu)
CACHE_POLICY=lru

# -----------------------------------------------
# Raft Consensus
# -----------------------------------------------
# Election timeout range in milliseconds (randomized)
RAFT_ELECTION_TIMEOUT_MIN=150
RAFT_ELECTION_TIMEOUT_MAX=300
# Heartbeat interval in milliseconds
RAFT_HEARTBEAT_INTERVAL=50

# -----------------------------------------------
# Logging
# -----------------------------------------------
# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
# Log format (json | text)
LOG_FORMAT=json
